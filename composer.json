{
    "name": "daniel-km/omeka-s-module-bulk-import",
    "type": "omeka-s-module",
    "description": "Module for Omeka S: Extensible bulk import module for xml, sql databases, spreedsheets, and json endpoints.",
    "keywords": [
        "Omeka S",
        "Omeka S module",
        "admin",
        "import",
        "migration"
    ],
    "license": "CECILL-2.1",
    "homepage": "https://gitlab.com/Daniel-KM/Omeka-S-module-BulkImport",
    "authors": [
        {
            "name": "Daniel Berthereau",
            "email": "Daniel.packagist@Berthereau.net"
        }
    ],
    "support": {
        "issues": "https://gitlab.com/Daniel-KM/Omeka-S-module-BulkImport/-/issues",
        "forum": "https://forum.omeka.org/"
    },
    "_require (not set until Omeka S merges PR #2412)": {
        "omeka/omeka-s": "^4.0",
        "daniel-km/omeka-s-module-common": "*"
    },
    "require": {
        "james-heinrich/getid3": "^2.0-dev",
        "mikehaertl/php-pdftk": "^0.13"
    },
    "replace": {
        "laminas/laminas-escaper": "*",
        "laminas/laminas-zendframework-bridge": "*"
    },
    "autoload": {
        "psr-4": {
            "BulkImport\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "BulkImportTest\\": "tests/BulkImportTest/"
        }
    },
    "config": {
        "platform": {
            "php": "7.4"
        }
    },
    "extra": {
        "installer-name": "BulkImport",
        "configurable": true
    }
}
